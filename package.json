    "@tanstack/query-sync-storage-persister": "^5.67.0",
    "@tanstack/react-query": "^5.67.0",
    "@tanstack/react-query-persist-client": "^5.67.0",
    "@tanstack/react-router": "^1.95.0",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.479.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.95.0",
